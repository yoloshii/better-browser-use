# better-browser-use configuration
# Copy to .env and fill in values: cp .env.example .env
# Install python-dotenv for auto-loading: pip install python-dotenv
# Or source manually: source .env && python scripts/server.py

# --- Server ---
# This is YOUR server's auth token — any string you choose to protect the HTTP endpoint.
# This is NOT the official browser-use cloud API key. No external account needed.
BROWSER_USE_TOKEN=
# BROWSER_USE_EVALUATE=1     # Set to 0 to disable arbitrary JS execution

# --- Stealth & Humanization ---
# BROWSER_USE_HUMANIZE=0     # Set to 1 to force humanization on all tiers
# BROWSER_USE_GEO=           # Geo profile: us, uk, de, jp, au, br, in, etc.

# --- Proxy (optional — bring your own; used by all tiers) ---
# PROXY_STRATEGY=static      # static (default) | port_pool | backconnect
# static — a single proxy URL (+ optional auth):
# PROXY_SERVER=              # HTTP or SOCKS5 proxy URL (e.g., http://proxy:8080)
# PROXY_USERNAME=
# PROXY_PASSWORD=
# port_pool — one host, several ports (first port used until live rotation ships):
# PROXY_HOST=
# PROXY_PORTS=               # comma-separated, e.g. 10001,10002,10003
# backconnect — residential sticky-session endpoint (provider username DSL):
# PROXY_PROVIDER=decodo      # decodo | generic (BrightData/Oxylabs-style)
# PROXY_BACKCONNECT_HOST=
# PROXY_BACKCONNECT_PORT=
# Geo-target the residential exit — keep PROXY_COUNTRY aligned with BROWSER_USE_GEO
# (a country mismatch vs the browser tz/locale is a fingerprint inconsistency, warned at launch):
# PROXY_COUNTRY=             # 2-letter ISO, e.g. us
# PROXY_STATE=
# PROXY_CITY=
# PROXY_ZIP=
# PROXY_SESSION_DURATION_MINUTES=   # sticky-session lifetime, 1–1440

# --- Tier 2 (CloakBrowser) ---
# CLOAKBROWSER_ENABLED=auto  # auto (use if installed) | 1 (require) | 0 (force Patchright)
# CLOAKBROWSER_AUTO_UPDATE=false   # allow binary auto-updates: true | false
# CLOAKBROWSER_GEOIP=auto    # auto | 0 (disable tz/locale GeoIP only; WebRTC-IP spoofing still applies)

# --- Tier 3 (Camoufox) ---
# CAMOUFOX_HEADLESS=         # empty = use default headless. virtual = headful inside a
#                            # Camoufox-managed Xvfb (less detectable; FAILS LOUD if Xvfb is
#                            # missing — never silently headless). true/1 = headless, false/0 = headful.

# --- CAPTCHA Solving (optional — pay-as-you-go) ---
# CAPSOLVER_API_KEY=         # CapSolver: fast AI solver (1-10s), ~$1-3/1000 solves
# TWOCAPTCHA_API_KEY=        # 2Captcha: human fallback (10-30s), broadest coverage

# --- WebMCP (Chrome 146+) ---
# BROWSER_USE_WEBMCP=auto    # auto = detect, 1 = force Chrome channel, 0 = disable
# BROWSER_USE_CHROME_CHANNEL= # chrome-dev, chrome-beta, chrome-canary, chrome
# BROWSER_USE_CHROME_PATH=   # Explicit Chrome binary path (overrides channel)
